# Environment Configuration for Open-Meteo MCP Server

# HTTP host to bind to (default: 0.0.0.0)
HOST=0.0.0.0

# HTTP port to bind to (default: 8888)
PORT=8888

# Base URL for Open-Meteo API (default: https://api.open-meteo.com)
API_BASE_URL=https://api.open-meteo.com

# HTTP request timeout in seconds (default: 30)
TIMEOUT_SECS=30

# Log level: trace, debug, info, warn, error (default: info)
LOG_LEVEL=info

# Transport mode: "stdio" (Claude Desktop) or "sse" (HTTP) (default: stdio)
TRANSPORT=stdio
