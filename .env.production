# Production environment configuration template
# Copy this file to .env and adjust values for your deployment

# Transport mode: "stdio" (Claude Desktop) or "sse" (HTTP)
TRANSPORT=sse

# HTTP server configuration
HOST=0.0.0.0
PORT=8888

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Request timeout in seconds (1-300)
TIMEOUT_SECS=30

# Open-Meteo API base URL
API_BASE_URL=https://api.open-meteo.com

# Application behavior
# Health check cache TTL in seconds (to avoid excessive API calls)
HEALTH_CHECK_TTL=30

# Graceful shutdown timeout in seconds
SHUTDOWN_TIMEOUT=10

# Advanced: Resource limits (for Kubernetes)
# Memory limit: 256M minimum recommended
# CPU limit: 0.5 cores minimum recommended
